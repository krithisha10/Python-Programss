import math
a = float(input("Enter the lenght of side a:"))
b = float(input("Enter the lenght of side b:"))
c = float(input("Enter the lenght of side c:"))
s = (a+b+c)/2
area = math.sqrt(s*(s-a)*(s-b)*(s-c))
print("Area of the triangle is:", area)

